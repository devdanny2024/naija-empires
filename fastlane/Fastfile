default_platform(:ios)

platform :ios do
  desc "Archive the Unity-generated Xcode project and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY"],
      is_key_content_base64: true
    )

    # game-ci outputs the Unity Xcode project under build/iOS/.
    xcodeproj = Dir["build/iOS/**/Unity-iPhone.xcodeproj"].first
    UI.user_error!("Unity-iPhone.xcodeproj not found under build/iOS") unless xcodeproj

    update_code_signing_settings(
      path: xcodeproj,
      use_automatic_signing: true,
      team_id: ENV["APPLE_TEAM_ID"]
    )

    build_app(
      project: xcodeproj,
      scheme: "Unity-iPhone",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
