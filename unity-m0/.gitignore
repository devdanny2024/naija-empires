# Unity generated — anchored to project root (leading /) so source folders such as
# Assets/Scripts/Build are NOT ignored (the unanchored form dropped BuildPlacer.cs).
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Stray nested Unity project accidentally created inside this one — never commit it
/My project/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider / VS Code
.vs/
.idea/
.vscode/
*.csproj
*.sln
*.user
*.userprefs

# OS
.DS_Store
Thumbs.db

# Builds
*.apk
*.aab
*.ipa

# Photon App Id is a credential — keep it out of the public repo (multiplayer is offline in this build)
/Assets/Photon/Fusion/Resources/PhotonAppSettings.asset
/Assets/Photon/Fusion/Resources/PhotonAppSettings.asset.meta
